rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuth()
        && userDocExists()
        && userDoc().data.role == 'admin';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isBootstrapAdminEmail() {
      // Hardened (audit H5): the bootstrap email must be VERIFIED, so a user
      // cannot self-provision admin by merely registering with this email
      // string. Remove this backdoor entirely once a real admin is provisioned
      // via a custom claim / the Firebase console.
      return request.auth.token.email_verified == true
        && request.auth.token.email in ['admin@gmail.com', 'admin@myroach.in'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && (
        request.resource.data.role == 'customer'
        || (request.resource.data.role == 'admin' && isBootstrapAdminEmail())
      );
      allow update: if isAdmin() || (
        isOwner(userId)
        && request.resource.data.role == resource.data.role
      );
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if (
        isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'paymentStatus',
          'trackingNumber',
          'updatedAt',
          'statusHistory'
        ])
      ) || (
        isAuth()
        && resource.data.userId == request.auth.uid
        && resource.data.status in ['pending', 'confirmed']
        && request.resource.data.status == 'cancelled'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'cancelledAt'])
      );
      allow delete: if isAdmin();
    }

    match /orderRequests/{requestId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.type in ['refund', 'exchange', 'cancel']
        && request.resource.data.policyAccepted == true
        && request.resource.data.reason is string
        && request.resource.data.reason.size() >= 10
        && request.resource.data.reason.size() <= 500
        && (
          request.resource.data.type != 'exchange'
          || (
            request.resource.data.exchangeDetails is string
            && request.resource.data.exchangeDetails.size() >= 3
            && request.resource.data.exchangeDetails.size() <= 300
          )
        );
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    match /subscribers/{subId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /newsletter/{docId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /cart/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if isAdmin();
    }

    match /wishlist/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if isAdmin();
    }

    match /razorpay_events/{eventId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}
